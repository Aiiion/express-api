FROM node:24.8.0-alpine3.22

WORKDIR /usr/src/app

# Copy package manifests first for cached installs
COPY package*.json ./

# Install all dependencies including devDependencies (nodemon, jest, etc.)
RUN npm install

# Install postgres client for pg_isready used in startup script
RUN apk add --no-cache postgresql-client

# Copy the rest of the application code
COPY . .

# Ensure startup scripts are executable
RUN chmod +x ./startup.sh ./startup.dev.sh

# Expose the application port
EXPOSE 3000

ENTRYPOINT ["./startup.dev.sh"]
